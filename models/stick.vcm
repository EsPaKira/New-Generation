    @part tags (west) texture "blocks:stick" region (0, 0.375, 0.3125, 0.5)
    @part tags (north) texture "blocks:stick" region (0.625, 0.375, 0.75, 0.5)
    @part tags (east) texture "blocks:stick" region (0.625, 0.375, 0.3125, 0.5)
    @part tags (top) texture "blocks:stick" region (0, 0.0625, 0.125, 0.375)
    @part tags (bottom) texture "blocks:stick" region (0.125, 0.0625, 0.25, 0.375)
}
